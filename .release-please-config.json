{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "go",
  "draft": false,
  "prerelease": false,
  "include-component-in-tag": true,
  "tag-separator": "/",
  "changelog-sections": [
    { "type": "feat", "section": "Features" },
    { "type": "fix", "section": "Bug Fixes" },
    { "type": "perf", "section": "Performance Improvements" },
    { "type": "revert", "section": "Reverts" },
    { "type": "refactor", "section": "Code Refactoring" },
    { "type": "deps", "section": "Dependencies" },
    { "type": "docs", "section": "Documentation", "hidden": true },
    { "type": "chore", "section": "Miscellaneous Chores", "hidden": true },
    { "type": "style", "section": "Styles", "hidden": true },
    { "type": "test", "section": "Tests", "hidden": true },
    { "type": "build", "section": "Build System", "hidden": true },
    { "type": "ci", "section": "Continuous Integration", "hidden": true }
  ],
  "packages": {
    ".": {
      "release-type": "go",
      "package-name": "go.loglayer.dev",
      "include-component-in-tag": false,
      "changelog-path": "CHANGELOG.md"
    },
    "transports/charmlog": {
      "release-type": "go",
      "package-name": "go.loglayer.dev/transports/charmlog",
      "component": "transports/charmlog",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md"
    },
    "transports/datadog": {
      "release-type": "go",
      "package-name": "go.loglayer.dev/transports/datadog",
      "component": "transports/datadog",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md"
    },
    "transports/http": {
      "release-type": "go",
      "package-name": "go.loglayer.dev/transports/http",
      "component": "transports/http",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md"
    },
    "transports/logrus": {
      "release-type": "go",
      "package-name": "go.loglayer.dev/transports/logrus",
      "component": "transports/logrus",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md"
    },
    "transports/otellog": {
      "release-type": "go",
      "package-name": "go.loglayer.dev/transports/otellog",
      "component": "transports/otellog",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md"
    },
    "transports/phuslu": {
      "release-type": "go",
      "package-name": "go.loglayer.dev/transports/phuslu",
      "component": "transports/phuslu",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md"
    },
    "transports/pretty": {
      "release-type": "go",
      "package-name": "go.loglayer.dev/transports/pretty",
      "component": "transports/pretty",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md"
    },
    "transports/zap": {
      "release-type": "go",
      "package-name": "go.loglayer.dev/transports/zap",
      "component": "transports/zap",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md"
    },
    "transports/zerolog": {
      "release-type": "go",
      "package-name": "go.loglayer.dev/transports/zerolog",
      "component": "transports/zerolog",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md"
    },
    "plugins/oteltrace": {
      "release-type": "go",
      "package-name": "go.loglayer.dev/plugins/oteltrace",
      "component": "plugins/oteltrace",
      "include-component-in-tag": true,
      "changelog-path": "CHANGELOG.md"
    }
  },
  "plugins": [
    {
      "type": "sentence-case"
    }
  ]
}
